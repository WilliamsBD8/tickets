# =============================================================================
# Raíz del repo — Docker Compose + opciones del contenedor `api`
#   Windows:  copy .env.example .env
#   Unix:     cp .env.example .env
#   docker compose up --build
# No commitees `.env` con secretos reales.
# =============================================================================
# Las claves de API (LLM, CORS, límites, etc.) son las mismas que en
# backend/.env.example; aquí las lee Compose y las inyecta en el servicio `api`.
# DATABASE_URL la arma el YAML (host `db`); no la pongas en este archivo salvo
# que sepas que estás sustituyendo el compose.
#
# Vite (VITE_*): solo aplica en desarrollo con `npm run dev` desde frontend/
# (plantilla frontend/.env.example). La imagen Docker del front usa `/api` por
# defecto; no hace falta VITE_API_URL en la raíz salvo que cambies el Dockerfile.
# =============================================================================

# --- Compose: Postgres y puertos publicados en el host ---
POSTGRES_PASSWORD=changeme_in_production
API_PORT=8000
FRONTEND_PORT=3000

# --- API en Docker (mismos nombres que backend/.env / pydantic-settings) ---
AUTO_SEED_CSV=false
LLM_PROVIDER=mock
AUTO_ANALYZE_ON_STARTUP=true
ANALYZE_STARTUP_MAX=50000
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:5173,http://localhost:5173
CSV_UPLOAD_MAX_BYTES=25000000
ASK_CONTEXT_MAX_TICKETS=48
ASK_CONTEXT_MAX_CHARS=24000

# Rutas dentro del contenedor (coinciden con volúmenes / imagen; ajústalas solo si cambias el compose)
DATASET_CSV_PATH=/app/data/tickets.csv
KNOWLEDGE_BASE_PATH=/app/knowledge_base/support_policies.md

# --- OpenAI (solo si LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-tu-clave
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

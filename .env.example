# Copia a `.env` en la raíz del repo para docker compose (opcional).
# No commitees `.env` con secretos reales.

# Contraseña de PostgreSQL (debe coincidir con la usada en DATABASE_URL del servicio api).
POSTGRES_PASSWORD=changeme_in_production

# Puerto publicado en el host para la API FastAPI.
API_PORT=8000

# Puerto del front (Nginx + build React). Abre http://127.0.0.1:3000
FRONTEND_PORT=3000

# true | false — importar CSV al arrancar si la base está vacía.
AUTO_SEED_CSV=true

# =============================================================================
# Implementación rápida (desde la carpeta frontend/)
#   Windows (PowerShell):  copy .env.example .env
#   macOS / Linux:        cp .env.example .env
# Luego: npm run dev. No commitees `.env`.
#
# Las variables VITE_* no van en el `.env` de la raíz: Compose no las usa.
# Con Docker, el front compilado llama al API bajo `/api` (Nginx); solo hace
# falta este archivo para desarrollo con Vite o builds fuera de Docker.
# =============================================================================
# En desarrollo, Vite proxea /api hacia esta URL (ver vite.config).
# =============================================================================

VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Solo para build de producción / preview estática (URL pública del API):
# VITE_API_URL=https://tu-api.example.com

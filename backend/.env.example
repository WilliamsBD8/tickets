# =============================================================================
# Implementación rápida (desde la carpeta backend/)
#   Windows (PowerShell):  copy .env.example .env
#   macOS / Linux:        cp .env.example .env
# Luego: uvicorn o el comando que uses en README. No commitees `.env`.
#
# Si levantas la API con Docker Compose, las mismas claves pueden ir en el
# `.env` de la raíz (plantilla en la raíz `.env.example`); Compose las inyecta
# al contenedor. En local sin Docker solo se lee este archivo.
# =============================================================================
# Variables con el mismo nombre que lee Pydantic (mayúsculas + guiones bajos).
# =============================================================================

# --- Valores por defecto razonables (local: SQLite + IA mock, sin API keys) ---
LLM_PROVIDER=mock
AUTO_SEED_CSV=true
AUTO_ANALYZE_ON_STARTUP=true
ANALYZE_STARTUP_MAX=50000
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CSV_UPLOAD_MAX_BYTES=25000000
ASK_CONTEXT_MAX_TICKETS=48
ASK_CONTEXT_MAX_CHARS=24000

# --- Base de datos ---
# Si NO defines DATABASE_URL, la API usa SQLite en backend/data/tickets.db (se crea al usar la app).
# Descomenta SOLO si quieres PostgreSQL (p. ej. compose en la raíz con puerto 5432 publicado):
# DATABASE_URL=postgresql+asyncpg://tickets:changeme_in_production@127.0.0.1:5432/tickets

# --- CSV de tickets (opcional) ---
# Si no defines DATASET_CSV_PATH, se busca dataset/tickets.csv o tickets.csv en la raíz del repo.
# DATASET_CSV_PATH=../dataset/tickets.csv

# --- Base de conocimiento para /ask (opcional) ---
# Por defecto: backend/knowledge_base/support_policies.md
# KNOWLEDGE_BASE_PATH=knowledge_base/support_policies.md

# --- OpenAI (solo si pones LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-tu-clave
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

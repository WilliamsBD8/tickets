# Opcional: SQLite local (por defecto: backend/data/tickets.db)
# DATABASE_URL=sqlite+aiosqlite:////ruta/absoluta/tickets.db

# PostgreSQL (async), p. ej. con Docker Compose en la raíz del repo:
# DATABASE_URL=postgresql+asyncpg://tickets:TU_PASSWORD@localhost:5432/tickets

# Ruta al CSV (por defecto: dataset/tickets.csv, tickets.csv en raíz, o /app/data/tickets.csv en Docker)
# DATASET_CSV_PATH=

# true | false — sembrar la BD si está vacía
# AUTO_SEED_CSV=true

# --- IA ---
# mock | openai
# LLM_PROVIDER=mock
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ruta al markdown de base de conocimiento (por defecto: backend/knowledge_base/support_policies.md)
# KNOWLEDGE_BASE_PATH=

# Analizar tickets sin IA al arrancar (mock: rápido; openai: respeta tope)
# AUTO_ANALYZE_ON_STARTUP=true
# ANALYZE_STARTUP_MAX=50000

# Orígenes CORS para el front (React/Vite en http://127.0.0.1:5173). Separados por coma.
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Tamaño máximo del CSV en POST /tickets/ingest (bytes, por defecto 25 MB)
# CSV_UPLOAD_MAX_BYTES=25000000

# Muestra de tickets que /ask lee de la BD (palabras de la pregunta o recientes)
# ASK_CONTEXT_MAX_TICKETS=48
# ASK_CONTEXT_MAX_CHARS=24000
